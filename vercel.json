{
  "installCommand": "npm ci --prefix nova-lp && npm ci --prefix numerologia-lp",
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/3tecnicas.html",
      "destination": "/3tecnicas",
      "permanent": true
    },
    {
      "source": "/3tecnicas",
      "destination": "/3tecnicas/",
      "permanent": true
    },
    {
      "source": "/numerologia",
      "destination": "/numerologia/",
      "permanent": true
    },
    {
      "source": "/nova",
      "destination": "/3tecnicas/",
      "permanent": true
    },
    {
      "source": "/nova/",
      "destination": "/3tecnicas/",
      "permanent": true
    },
    {
      "source": "/formulario",
      "destination": "/formulario/",
      "permanent": true
    }
  ]
}
